# Frontend variables exposed by Vite.
VITE_APP_NAME=SmartClass
# Leave empty on Vercel so the UI calls same-origin /api (serverless Express).
# For local dev with separate API: VITE_API_BASE_URL=http://localhost:3001
VITE_API_BASE_URL=
VITE_API_TIMEOUT_MS=15000
VITE_ANALYTICS_ID=

# Dev-only proxy target used by vite.config.js when VITE_API_BASE_URL is empty.
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:3001

# Backend variables for local API runs.
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
DATABASE_PATH=server/data/smartclass.db
UPLOAD_DIR=server/uploads
MAX_UPLOAD_MB=25
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
SEED_ON_EMPTY=true
